---
layout: gallery.njk
pagination:
  data: collections.galleries
  size: 1
  alias: gallery
permalink: "/galleries/{{ gallery.slug }}/"
eleventyComputed:
  pageTitle: "{{ gallery.title }}"
  description: "{{ gallery.description }}"
---

<div class="gallery-detail">
  <div class="gallery-header">
    <h1>{{ gallery.title }}</h1>
    {% if gallery.description %}
    <p class="gallery-description">{{ gallery.description }}</p>
    {% endif %}
    <p class="gallery-meta">
      {% if gallery.location %}{{ gallery.location }}{% endif %}
      {% if gallery.date %} &middot; {{ gallery.date }}{% endif %}
      &middot; {{ gallery.imageCount }} photographs
    </p>
  </div>

  <div class="masonry-grid">
    {% for image in gallery.images %}
    <div class="masonry-item">
      {% img
        src=image,
        alt=gallery.title + " — " + (loop.index | string),
        className="masonry-img",
        gallerySlug=gallery.slug,
        sizes="(min-width: 768px) 33vw, 50vw",
        widths=[400, 600, 900, 1200]
      %}
    </div>
    {% endfor %}
  </div>

  <div class="gallery-back">
    <a href="/">&larr; Home</a>
  </div>
</div>
