---
layout: base.njk
pageTitle: Galleries
permalink: /galleries/
description: "All photo galleries from Hugues Costa's travels through India and Nepal, 1980-1981"
---

<div class="page-header">
  <h1>Galleries</h1>
</div>

<section class="galleries-section">
  <ul class="gallery-grid">
    {% for gallery in collections.galleries %}
    {% if gallery.coverImage %}
    <li class="gallery-card">
      <a href="/galleries/{{ gallery.slug }}/">
        {% img
          src=gallery.coverImage,
          alt=gallery.title,
          className="gallery-card__image",
          gallerySlug=gallery.slug,
          sizes="(min-width: 1200px) 25vw, (min-width: 768px) 33vw, 50vw"
        %}
        <div class="gallery-card__overlay">
          <h2>{{ gallery.title }}</h2>
          <p>{{ gallery.location }}{% if gallery.imageCount %} &middot; {{ gallery.imageCount }} photos{% endif %}</p>
        </div>
      </a>
    </li>
    {% endif %}
    {% endfor %}
  </ul>
</section>
